---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import "../styles/global.css";
const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="DCBMUN is a student-run, not-for-profit Model United Nations conference designed to introduce high school students to a world of diplomacy, debate, and collaboration." />
		<meta name="keywords" content="DCBMUN, Dr. Charles Best, Model United Nations, diplomacy, debate, collaboration, Vancouver, Coquitlam, Burnaby, Port Coquitlam, Port Moody, British Columbia, BC" />
		<link rel="shortcut icon" href="/logo.png" type="image/png" />
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col text-dark-500 bg-light-500 font-body">
		<Navbar />

		<main class="flex-1">
			<slot />
		</main>

		<Footer />
	</body>
</html>
