---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — DCBMUN">
	<div class="w-full h-30 flex items-center justify-center">
		<h1 class="text-4xl font-headings font-bold text-dark-500">404 - Page Not Found</h1>
	</div>
	<div class="w-1/2 mx-auto my-10 font-body">
		<p class="text-xl text-dark-500 text-center">
			The page you&apos;re looking for either doesn&apos;t exist or is under construction.
		</p>
	</div>
</Layout>
